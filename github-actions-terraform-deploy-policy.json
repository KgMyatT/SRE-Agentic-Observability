{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AgenticSREDeployCore",
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*", "ec2:Create*", "ec2:Delete*", "ec2:Modify*", "ec2:Attach*", "ec2:Detach*", "ec2:Allocate*", "ec2:Release*", "ec2:Replace*", "ec2:Associate*", "ec2:Disassociate*", "ec2:Authorize*", "ec2:Revoke*",
        "elasticloadbalancing:Describe*", "elasticloadbalancing:Create*", "elasticloadbalancing:Delete*", "elasticloadbalancing:Modify*", "elasticloadbalancing:AddTags", "elasticloadbalancing:RemoveTags",
        "ecs:Describe*", "ecs:List*", "ecs:Create*", "ecs:Delete*", "ecs:Update*", "ecs:Put*", "ecs:Register*", "ecs:Deregister*", "ecs:Tag*", "ecs:Untag*",
        "application-autoscaling:*",
        "iam:Get*", "iam:List*", "iam:Create*", "iam:Delete*", "iam:Update*", "iam:Attach*", "iam:Detach*", "iam:Put*", "iam:Tag*", "iam:Untag*",
        "logs:Describe*", "logs:List*", "logs:Create*", "logs:Delete*", "logs:Put*", "logs:Tag*", "logs:Untag*",
        "secretsmanager:Describe*", "secretsmanager:Get*", "secretsmanager:List*", "secretsmanager:Create*", "secretsmanager:Delete*", "secretsmanager:Tag*", "secretsmanager:Untag*",
        "elasticache:Describe*", "elasticache:Create*", "elasticache:Delete*", "elasticache:Modify*", "elasticache:AddTags*", "elasticache:RemoveTags*",
        "cloudwatch:Describe*", "cloudwatch:Get*", "cloudwatch:Put*", "cloudwatch:Delete*",
        "sns:Get*", "sns:List*", "sns:Create*", "sns:Delete*", "sns:Set*", "sns:Tag*", "sns:Untag*", "sns:Subscribe", "sns:Unsubscribe",
        "servicediscovery:*",
        "s3:ListBucket", "s3:GetBucketLocation", "s3:GetEncryptionConfiguration", "s3:GetObject", "s3:PutObject", "s3:DeleteObject",
        "dynamodb:DescribeTable", "dynamodb:GetItem", "dynamodb:PutItem", "dynamodb:DeleteItem", "dynamodb:UpdateItem"
      ],
      "Resource": "*"
    },
    {
      "Sid": "IamPassRoleECS",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "*",
      "Condition": {
        "StringEqualsIfExists": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    }
  ]
}